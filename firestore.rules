rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Helpers */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function memberDoc(orgId) {
      return /databases/$(database)/documents/orgs/$(orgId)/members/$(uid());
    }

    // User is member of org
    function isMember(orgId) {
      return signedIn() && exists(memberDoc(orgId));
    }

    // Member approved by admin
    function isApproved(orgId) {
      return isMember(orgId) && get(memberDoc(orgId)).data.status == "APPROVED";
    }

    // Org admin
    function isAdmin(orgId) {
      return isApproved(orgId) && get(memberDoc(orgId)).data.role == "ADMIN";
    }

    // Coach or admin
    function isCoachOrAdmin(orgId) {
      return isApproved(orgId) && get(memberDoc(orgId)).data.role in ["ADMIN", "COACH"];
    }

    // Access to own user doc only
    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    /** users/{uid} */
    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    /** orgs/{orgId} */
    match /orgs/{orgId} {
      allow read: if isApproved(orgId);

      // Org create: requester must be owner
      allow create: if signedIn()
        && request.resource.data.ownerUid == uid();

      // Org update/delete: admin only
      allow update, delete: if isAdmin(orgId);

      /** members */
      match /members/{memberId} {
        allow read: if isApproved(orgId);

        // Self-signup as pending member
        allow create: if signedIn()
          && memberId == uid()
          && request.resource.data.uid == uid()
          && request.resource.data.role in ["USER", "COACH"]
          && request.resource.data.status == "PENDING";

        // Admin can manage member doc
        // Self can update limited fields only
        allow update: if
          isAdmin(orgId)
          ||
          (
            signedIn()
            && memberId == uid()
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status
          );

        allow delete: if isAdmin(orgId);
      }

      /** players */
      match /players/{playerId} {
        allow read: if isApproved(orgId);
        allow create, update: if isCoachOrAdmin(orgId);
        allow delete: if false;
      }

      /** formations */
      match /formations/{formationId} {
        allow read: if isApproved(orgId);
        allow create, update, delete: if isApproved(orgId);
      }

      /** tacticBooks (playbooks) */
      match /tacticBooks/{bookId} {
        allow read: if isApproved(orgId);
        allow create, update: if isApproved(orgId);
        allow delete: if false;
      }

      /** tacticBoards */
      match /tacticBoards/{boardId} {
        allow read: if isApproved(orgId);
        allow create, update: if isApproved(orgId);
        allow delete: if false;

        // state/current
        match /state/{stateId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;
        }

        // state/chunks/*
        match /state/chunks/{chunkId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;
        }

        // state/pointers/index
        match /state/pointers/{pointerId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;
        }

        // state/{stateId}/versions/*
        match /state/{stateId}/versions/{versionId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;

          match /snapshot/{docId} {
            allow read: if isApproved(orgId);
            allow create, update: if isApproved(orgId);
            allow delete: if false;
          }

          match /snapshotChunks/{chunkId} {
            allow read: if isApproved(orgId);
            allow create, update: if isApproved(orgId);
            allow delete: if false;
          }
        }

        // animations/*
        match /animations/{animationId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;

          // animations/{animationId}/tracks/*
          match /tracks/{trackId} {
            allow read: if isApproved(orgId);
            allow create, update: if isApproved(orgId);
            allow delete: if false;
          }
        }

        // comments
        match /comments/{commentId} {
          allow read: if isApproved(orgId);
          allow create, update: if isApproved(orgId);
          allow delete: if false;
        }
      }
    }

    /** Default deny */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
